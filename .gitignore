.direnv

# Compiled binaries
bin/
dist/

# Persistent data directory
data/

# Environment variables, which may contain secrets
.env.*
# .env.example is an exception as it only contains dummy secrets.
!.env.example

# Unit test code coverage output
.coverage.*

node_modules/

# System files
.DS_Store

# Playwright output
/playwright-report/
/playwright/.cache/
/e2e-results/

/.direnv
result*

# Scratch directories for sharing data with AI agents.
/reference
/tmp

# Temporary screenshots pasted into the root for AI agents.
/image*.png
